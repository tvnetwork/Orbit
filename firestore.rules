rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Auth tokens do not contain custom claims. Admin status is strictly verified against a trusted record or hardcoded email for bootstrap.
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'oladoyeheritage445@gmail.com'
      ); 
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.keys().size() <= 23 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['freelancer', 'client', 'admin'] &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100) &&
             (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 1000) &&
             (data.get('professionalTitle', '') is string && data.get('professionalTitle', '').size() <= 150) &&
             (data.get('githubUrl', '') is string && data.get('githubUrl', '').size() <= 500) &&
             (data.get('linkedinUrl', '') is string && data.get('linkedinUrl', '').size() <= 500) &&
             (data.get('twitterUrl', '') is string && data.get('twitterUrl', '').size() <= 500) &&
             (data.get('websiteUrl', '') is string && data.get('websiteUrl', '').size() <= 500) &&
             (data.get('verificationStatus', 'none') in ['none', 'pending', 'verified']) &&
             (data.get('rating', 0) is number && data.get('rating', 0) >= 0 && data.get('rating', 0) <= 5);
    }

    function isValidJob(data) {
      return data.keys().hasAll(['clientId', 'title', 'description', 'budget', 'type', 'status', 'createdAt']) &&
             data.keys().size() <= 15 &&
             data.clientId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 10000 &&
             data.budget is number && data.budget >= 0 &&
             data.type in ['fixed', 'hourly'] &&
             data.status in ['open', 'in_progress', 'completed', 'cancelled'];
    }

    function isValidProposal(data) {
      return data.keys().hasAll(['jobId', 'freelancerId', 'coverLetter', 'bidAmount', 'status', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.freelancerId == request.auth.uid &&
             data.coverLetter is string && data.coverLetter.size() <= 5000 &&
             data.bidAmount is number && data.bidAmount > 0 &&
             data.status in ['unread', 'shortlisted', 'interviewing', 'hired', 'rejected', 'withdrawn'];
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'type', 'status', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.userId is string &&
             data.amount is number &&
             data.type in ['deposit', 'withdrawal', 'payment_received', 'payment_sent', 'escrow_hold'] &&
             data.status in ['pending', 'completed', 'failed'];
    }

    function isValidReview(data) {
      return data.keys().hasAll(['freelancerId', 'clientId', 'rating', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.clientId == request.auth.uid &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             (data.get('comment', '') is string && data.get('comment', '').size() <= 5000) &&
             (data.get('clientName', '') is string && data.get('clientName', '').size() <= 100) &&
             (data.get('clientPhoto', '') is string && data.get('clientPhoto', '').size() <= 1000);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isAdmin() || resource.data.role == 'freelancer'); // Allow listing freelancers for discovery or all for admin
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(userId) && isValidUser(incoming()) && (
          // Action: Profile Edit
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'professionalTitle', 'bio', 'skills', 'location', 'hourlyRate', 'timezone', 'languages', 'githubUrl', 'linkedinUrl', 'twitterUrl', 'websiteUrl', 'portfolio', 'lastActive']) ||
          // Action: Request Verification
          (incoming().diff(existing()).affectedKeys().hasOnly(['verificationStatus']) && incoming().verificationStatus == 'pending' && existing().verificationStatus == 'none')
        ) && 
        incoming().uid == existing().uid && 
        incoming().role == existing().role && 
        incoming().createdAt == existing().createdAt)
      );
    }

    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidJob(incoming()) && incoming().createdAt == request.time && 
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'client';
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(existing().clientId) && isValidJob(incoming()) && (
          // Action: Edit Details
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'budget', 'type', 'category', 'updatedAt']) ||
          // Action: Close/Cancel Job
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status in ['completed', 'cancelled'])
        ) && 
        incoming().clientId == existing().clientId && 
        incoming().createdAt == existing().createdAt)
      );
      allow delete: if isAdmin();
    }

    match /proposals/{proposalId} {
      allow read: if isSignedIn() && (isOwner(existing().freelancerId) || isOwner(get(/databases/$(database)/documents/jobs/$(existing().jobId)).data.clientId) || isAdmin());
      allow create: if isSignedIn() && isValidProposal(incoming()) && incoming().createdAt == request.time &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'freelancer' &&
                      exists(/databases/$(database)/documents/jobs/$(incoming().jobId)) &&
                      get(/databases/$(database)/documents/jobs/$(incoming().jobId)).data.status == 'open';
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(existing().freelancerId) && incoming().diff(existing()).affectedKeys().hasOnly(['coverLetter', 'bidAmount', 'status']) && incoming().status == 'withdrawn') ||
        (isOwner(get(/databases/$(database)/documents/jobs/$(existing().jobId)).data.clientId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
    }

    match /contracts/{contractId} {
      allow read: if isSignedIn() && (isOwner(existing().clientId) || isOwner(existing().freelancerId) || isAdmin());
      allow create: if isAdmin(); // Contracts are system managed or created via client action that triggers a backend function
      allow update: if isAdmin() || (isSignedIn() && (isOwner(existing().clientId) || isOwner(existing().freelancerId)) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']));
    }

    match /transactions/{transactionId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create, update, delete: if isAdmin(); // Transactions are absolute system truth
    }

    match /kyc/{kycId} {
      allow read, update: if isAdmin() || (isSignedIn() && isOwner(existing().userId));
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().status == 'pending';
    }

    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidReview(incoming()) && incoming().createdAt == request.time &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'client';
      allow delete: if isAdmin();
    }

    match /community_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid && 
                      incoming().createdAt == request.time && 
                      incoming().text is string && incoming().text.size() <= 2000;
      allow delete: if isAdmin() || isOwner(existing().senderId);
    }

    match /cohorts/{cohortId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin(); // Cohorts are managed by admins currently
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().senderId == request.auth.uid && 
                        incoming().createdAt == request.time && 
                        incoming().text is string && incoming().text.size() <= 2000;
        allow delete: if isAdmin() || isOwner(existing().senderId);
      }
      
      match /members/{userId} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(userId);
      }
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in existing().participantIds || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid in incoming().participantIds || isAdmin());
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds || isAdmin());
      allow create: if isSignedIn() && (request.auth.uid == incoming().senderId || isAdmin()) &&
                      (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds || isAdmin()) &&
                      incoming().createdAt == request.time;
    }
  }
}
